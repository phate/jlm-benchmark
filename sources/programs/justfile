_default:
    @just --list


################### Free & open source programs #####################
####### These programs are real open-source C programs.    ##########
####### Their source tarballs are checked into the repo.   ##########
#####################################################################

# For the open source programs, we must compile them normally to extract commands.
# For this, we specify the exact compiler and flags to ensure reproducability
export CC := `llvm-config-18 --bindir` / "clang"
export CFLAGS := "-std=c17 -D_POSIX_C_SOURCE=200809L -D_GNU_SOURCE"

########################### Emacs 29.4 ##############################
download-emacs:
    [ -f emacs-29.4.tar.gz ] || \
        wget https://ftpmirror.gnu.org/emacs/emacs-29.4.tar.gz

extract-emacs: download-emacs
    #!/usr/bin/bash

    # Skip extracting if it is already extracted
    if [[ -d emacs-29.4 ]]; then
       exit 0
    fi

    tar xzf emacs-29.4.tar.gz
    # emacs requires a full build to create needed config files
    cd emacs-29.4 && ./configure && bear intercept -- make -j12

build-emacs: extract-emacs
# Do nothing here as extracting emacs already builds it

####################### Ghostscript 10.04.0 #########################
download-ghostscript:
    [ -f ghostscript-10.04.0.tar.gz ] || \
        wget https://github.com/ArtifexSoftware/ghostpdl-downloads/releases/download/gs10040/ghostscript-10.04.0.tar.gz

extract-ghostscript: download-ghostscript
    #!/usr/bin/bash -eux

    # Skip extracting if it is already extracted
    if [[ -d ghostscript-10.04.0 ]]; then
       exit 0
    fi

    tar xzf ghostscript-10.04.0.tar.gz
    cd ghostscript-10.04.0
    ./configure
    bear intercept -- make -j12

build-ghostscript: extract-ghostscript
# Do nothing here as extracting already builds it

########################### gdb 15.2 ################################
download-gdb:
    [ -f gdb-15.2.tar.gz ] || \
        wget https://ftp.gnu.org/gnu/gdb/gdb-15.2.tar.gz

extract-gdb: download-gdb
    #!/usr/bin/bash -eux

    # Skip extracting if it is already extracted
    if [[ -d gdb-15.2 ]]; then
      exit 0
    fi

    tar xzf gdb-15.2.tar.gz
    # gdb requires a full build to create its config files
    cd gdb-15.2 && ./configure && bear intercept -- make -j12

build-gdb: extract-gdb
# Do nothing here, as extracting gdb already involves building it

######################### sendmail 8.18.1 ###########################
download-sendmail:
    [ -f sendmail.8.18.1.tar.gz ] || \
        wget https://ftp.sendmail.org/sendmail.8.18.1.tar.gz

extract-sendmail: download-sendmail
    #!/usr/bin/bash -eux

    # Skip extracting if it is already extracted
    if [[ -d sendmail-8.18.1 ]]; then
      exit 0
    fi

    tar xzf sendmail.8.18.1.tar.gz

    # Manually do some "configuration" to avoid needing to make a build directory
    ln -s ../include/sm/os/sm_os_linux.h sendmail-8.18.1/editmap/sm_os.h
    ln -s ../include/sm/os/sm_os_linux.h sendmail-8.18.1/libsmdb/sm_os.h
    ln -s ../include/sm/os/sm_os_linux.h sendmail-8.18.1/libsm/sm_os.h
    ln -s ../include/sm/os/sm_os_linux.h sendmail-8.18.1/libsmutil/sm_os.h
    ln -s ../include/sm/os/sm_os_linux.h sendmail-8.18.1/mail.local/sm_os.h
    ln -s ../include/sm/os/sm_os_linux.h sendmail-8.18.1/mailstats/sm_os.h
    ln -s ../include/sm/os/sm_os_linux.h sendmail-8.18.1/makemap/sm_os.h
    ln -s ../include/sm/os/sm_os_linux.h sendmail-8.18.1/praliases/sm_os.h
    ln -s ../include/sm/os/sm_os_linux.h sendmail-8.18.1/rmail/sm_os.h
    ln -s ../include/sm/os/sm_os_linux.h sendmail-8.18.1/sendmail/sm_os.h
    ln -s ../include/sm/os/sm_os_linux.h sendmail-8.18.1/smrsh/sm_os.h
    ln -s ../include/sm/os/sm_os_linux.h sendmail-8.18.1/vacation/sm_os.h

clean-sendmail:
    # Make clean does not properly clean sendmail, so fully delete it on rebuilds
    rm -rf sendmail-8.18.1

build-sendmail: clean-sendmail extract-sendmail
    #!/usr/bin/bash -eu
    cd sendmail-8.18.1

    # Create config with CC
    echo "\
    define(\`confCC', \`$CC')
    " > devtools/Site/site.config.m4
    # The below command in the above file adds CFLAGS, that went too wild
    # APPENDDEF(\`confCCOPTS', \`$CFLAGS')

    # Delete previous builds
    find * -name "obj.*" -exec rm -r {} + -depth

    make clean
    bear intercept -- make -j12

####################### "All of the above" ##########################
# Extracts all the free C benchmarks. Downloads them first if missing.
extract-all-free: extract-emacs extract-ghostscript extract-gdb extract-sendmail

# Builds all the free C benchmarks
build-all-free: build-emacs build-ghostscript build-gdb build-sendmail

# Removes all unpacked free C benchmarks, but does not delete downloads
clean-all-free:
    rm -rf emacs-29.4 ghostscript-10.04.0 gdb-15.2 sendmail-8.18.1


############################ Polybench ##############################
######## We already have polybench extracted in the repo ############
#####################################################################


######################## Embench-iot 1.0 ############################
############ Small benchmarks of embedded workloads #################
#####################################################################
download-embench:
    [ -f embench-1.0.zip ] || \
      wget https://github.com/embench/embench-iot/archive/refs/tags/embench-1.0.zip

extract-embench: download-embench
    #!/usr/bin/bash -eux

    # Skip extracting if it is already extracted
    if [[ -d embench-1.0 ]]; then
      exit 0
    fi

    unzip embench-1.0.zip
    # Give the folder a nicer name
    mv embench-iot-embench-1.0 embench-1.0

# Removes the extracted folder, but does not delete downloads
clean-embench:
    rm -rf embench-1.0

########################### SPEC2017 redist ############################
### Command for extracting from SPEC2017's redistributable_sources/ ####
########################################################################

redist2017-dir := "redist2017"
redist2017-srcs := redist2017-dir / "redistributable_sources"
redist2017-extracted := redist2017-dir / "extracted"

extract-redist2017-perlbench:
    #!/usr/bin/bash -eux
    [[ -d {{redist2017-extracted}}/perl-5.22.1 ]] && exit 0

    mkdir -p {{redist2017-extracted}}
    tar -xvf {{redist2017-srcs}}/original/500.perlbench/perl-5.22.1.tar.xz -C {{redist2017-extracted}}

    pushd {{redist2017-extracted}}/perl-5.22.1
    ./Configure -Dcc="{{CC}}" -Accflags="{{CFLAGS}}" -de
    popd

extract-redist2017-common name:
    #!/usr/bin/bash -eux
    [[ -d {{redist2017-extracted}}/{{name}} ]] && exit 0
    mkdir -p {{redist2017-extracted}}
    tar -xvf {{redist2017-srcs}}/modified/{{name}}.tar.xz -C {{redist2017-extracted}}

extract-redist2017-imagick:
    #!/usr/bin/bash -eux
    [[ -d {{redist2017-extracted}}/ImageMagick-6.8.9-1 ]] && exit 0

    mkdir -p {{redist2017-extracted}}
    tar -xvf {{redist2017-srcs}}/original/538.imagick/ImageMagick-6.8.9-1.tar.xz -C {{redist2017-extracted}}

    cd {{redist2017-extracted}}/ImageMagick-6.8.9-1
    # SPEC uses these options, by hard coding them into magick-config.h
    ./configure --with-quantum-depth=16 --disable-hdri \
                --without-bzlib --disable-cipher \
                --without-djvu --without-fontconfig \
                --without-freetype \
                --without-jbig --without-jpeg \
                --without-lcms --without-lcms2 \
                --without-openjp2 --without-lqr \
                --without-lzma --without-pango \
                --without-png --without-zlib \
                --without-tiff --without-webp



extract-redist2017: extract-redist2017-perlbench \
                    (extract-redist2017-common "502.gcc_r") \
                    (extract-redist2017-common "507.cactuBSSN_r") \
                    (extract-redist2017-common "525.x264_r") \
                    (extract-redist2017-common "526.blender_r") \
                    extract-redist2017-imagick \
                    (extract-redist2017-common "544.nab_r") \
                    (extract-redist2017-common "557.xz_r")

clean-redist2017:
    rm -rf {{redist2017-extracted}}


############################## SPEC2017 ################################
###  The below commands only work if you have a cpu2017.tar.xz file  ###
########################################################################

cpu2017-tar := "cpu2017.tar.xz"
cpu2017-dir := "cpu2017"

extract-cpu2017:
    #!/usr/bin/bash -eux
    if [ ! -d {{cpu2017-dir}} ]; then
       mkdir -p {{cpu2017-dir}}/install_archives
       ln -s `readlink -f {{cpu2017-tar}}` {{cpu2017-dir}}/install_archives/cpu2017.tar.xz
       cd {{cpu2017-dir}}
       tar -xvf install_archives/cpu2017.tar.xz \
            tools/bin/linux-x86_64 \
            bin/harness/runcpu \
            bin/scripts.misc/exec_test \
            install.sh

        ./install.sh -f
    fi

install-cpu2017-config:
    cp -r --update=all {{redist2017-dir}}/config {{cpu2017-dir}}

build-cpu2017 config="clang-config": extract-cpu2017 install-cpu2017-config
    #!/usr/bin/bash -eux
    cd {{cpu2017-dir}}
    source shrc
    set -euxo pipefail

    export LLVM_BIN_PATH=`llvm-config-18 --bindir`

    runcpu --config={{config}} --size=test --copies=1 --noreportable --iterations=1 \
        500.perlbench \
        502.gcc \
        505.mcf \
        507.cactuBSSN \
        525.x264 \
        526.blender \
        538.imagick \
        557.xz \
        544.nab

# Used to test compiling and running SPEC2017 using jlc
jlc-cpu2017: (build-cpu2017 "jlc-config")

clean-cpu2017:
    rm -rf {{cpu2017-dir}}


###########################################################################
###           Cleanup. Does not delete any downloads.                   ###
###########################################################################

clean-all: clean-all-free clean-embench clean-redist2017 clean-cpu2017
