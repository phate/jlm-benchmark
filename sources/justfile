################ Creating sources.json yourself ##################
###  This file is only relevant if you want to make            ###
###  your own sources.json file from scratch.                  ###
###  This is only for those who are particularily interested.  ###
###  You also must have your own cpu2017.tar.xz to do this     ###
##################################################################

_default:
    @just --list

# Builds all benchmarks while tracing the compilation commands
build-all-benchmarks:
    just programs/build-all-free
    just programs/build-cpu2017
    just programs/extract-redist2017
    just programs/extract-embench

    # Polybench is already extracted in the repo
    # Polybench and embench are not built and traced, as their compilation commands are simple

# After all benchmarks have been built and traced, create sources.json
create-sources-json:
    ./create_sources_json.py --output sources.json
